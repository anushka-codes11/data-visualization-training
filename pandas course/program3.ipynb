   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "data = [10, np.nan, 30, np.nan, 50, 60, np.nan]\n",
    "s = pd.Series(data)\n",
    "\n",
    "print(\"Before filling:\\n\", s.isnull().sum())\n",
    "\n",
    "# Mean se fill karein\n",
    "s = s.fillna(s.mean())\n",
    "\n",
    "print(\"\\nAfter filling:\\n\", s)\n",
    "print(\"Missing count after:\", s.isnull().sum())"
   ]
  }
 ],
